# Copy this file to .env and fill in the values.
# .env is excluded from git — never commit your actual secrets.

# ─── Auth ─────────────────────────────────────────────────────────────
# Required: secret key for signing JWT login tokens.
# Generate one with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# Optional: pre-set the admin account password on first startup.
# If not set, you will be prompted to set a password on first visit.
# ADMIN_PASSWORD=change-me

# ─── Internal service API ─────────────────────────────────────────────
# Enables /api/internal/* endpoints for service-to-service communication
# (e.g. a separate registration container on the same Docker network).
# Only used when DB_BACKEND=postgres. Generate with: openssl rand -hex 32
# INTERNAL_API_KEY=change-me-to-a-long-random-string

# ─── Database ─────────────────────────────────────────────────────────
# Options: "sqlite" (default, one file per tenant) or "postgres"
DB_BACKEND=sqlite

# Required when DB_BACKEND=postgres.
# In Docker use the service name "postgres" as the host (not localhost).
# DATABASE_URL=postgres://benchlog:change-me@postgres:5432/benchlog
# POSTGRES_PASSWORD=change-me-strong-password

# ─── Image Storage ────────────────────────────────────────────────────
# Options: "local" (stores images on disk, default) or "r2" (Cloudflare R2)
STORAGE_BACKEND=local

# Required when STORAGE_BACKEND=r2.
# Find these in the Cloudflare dashboard → R2 → Manage R2 API Tokens.
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_BUCKET=your-bucket-name
# R2_ACCESS_KEY=your-r2-access-key-id
# R2_SECRET_KEY=your-r2-secret-access-key
# R2_PUBLIC_URL=https://pub-xxx.r2.dev
# Only needed for non-default jurisdictions (EU, EEUR, APAC):
# R2_ENDPOINT=https://your-account-id.eu.r2.cloudflarestorage.com
