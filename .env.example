# Copy this file to .env and fill in the values
# .env is excluded from git — never commit your actual secrets

# Required: secret key for signing JWT login tokens
# Generate one with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# ─── Image Storage ────────────────────────────────────────────────────
# Options: "local" (stores images on disk, default) or "r2" (Cloudflare R2)
STORAGE_BACKEND=local

# Required when STORAGE_BACKEND=r2
# Find these in the Cloudflare dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY=your-r2-access-key-id
R2_SECRET_KEY=your-r2-secret-access-key
R2_BUCKET=your-bucket-name
R2_PUBLIC_URL=https://your-bucket.your-account-id.r2.dev
# Only needed for non-default jurisdictions (EU, EEUR, APAC):
# R2_ENDPOINT=https://your-account-id.eu.r2.cloudflarestorage.com
# Or use a custom domain: R2_PUBLIC_URL=https://images.yourdomain.com
